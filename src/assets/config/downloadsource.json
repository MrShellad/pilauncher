    "java": [
      {
        "id": "adoptium",
        "name": "Adoptium官方源",
        "type": "api",
        "packages": [
          "jre",
          "jdk"
        ],
        "api": "https://api.adoptium.net/v3/assets/feature_releases/{version}/ga?architecture={arch}&heap_size=normal&image_type={package}&jvm_impl=hotspot&os={os}"
      },
      {
        "id": "zulu",
        "name": "Azul Zulu源",
        "type": "api",
        "packages": [
          "jre",
          "jdk"
        ],
        "api": "https://api.azul.com/metadata/v1/zulu/packages?java_version={version}&os={os}&arch={arch}&hw_bitness={bitness}&archive_type={archive}&java_package_type={package}&latest=true"
      },
      {
        "id": "aks",
        "name": "微软源",
        "type": "direct",
        "packages": [
          "jdk"
        ],
        "template": "https://aka.ms/download-jdk/microsoft-jdk-{version}-{os}-{arch}.{ext}"
      }
